# =============================================
# APPLICATION
# =============================================
APP_NAME=SilaBuys
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# =============================================
# DATABASE (PostgreSQL 16)
# =============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=silabuys
POSTGRES_USER=silabuys_user
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+asyncpg://silabuys_user:change-this-password@localhost:5432/silabuys

# =============================================
# JWT TOKENS
# =============================================
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# REDIS (Cache + Rate Limiting)
# =============================================
REDIS_URL=redis://localhost:6379/0

# =============================================
# MINIO (File Storage)
# =============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change-minio-access-key
MINIO_SECRET_KEY=change-minio-secret-key
MINIO_BUCKET_NAME=silabuys
MINIO_USE_SSL=false

# =============================================
# OPENAI
# =============================================
# OPENAI_API_KEY=sk-...  # ixtiyoriy: cloud provider uchun
OPENAI_MODEL=llama3.2
OPENAI_BASE_URL=http://host.docker.internal:11434/v1  # local Ollama
OPENAI_MAX_TOKENS=4096
AI_RATE_LIMIT_PER_HOUR=20

# =============================================
# ENCRYPTION (Fernet symmetric key for sensitive DB fields)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================
ENCRYPTION_KEY=change-this-to-a-fernet-key

# =============================================
# CORS
# =============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================
# FIRST SUPER ADMIN (seed data)
# =============================================
FIRST_SUPERADMIN_EMAIL=admin@silabuys.uz
FIRST_SUPERADMIN_PASSWORD=change-this-admin-password
