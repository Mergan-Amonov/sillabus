# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_NAME=SilaBuys
APP_ENV=production
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# ─── DOMAIN ───────────────────────────────────────────────────────────────────
DOMAIN=silabuys.uz
SSL_EMAIL=admin@silabuys.uz
NEXT_PUBLIC_API_URL=https://silabuys.uz

# ─── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_DB=silabuys
POSTGRES_USER=silabuys_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://silabuys_user:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/silabuys

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0

# ─── MINIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_THIS_MINIO_USER
MINIO_SECRET_KEY=CHANGE_THIS_MINIO_PASSWORD_MIN_8_CHARS
MINIO_BUCKET_NAME=silabuys
MINIO_USE_SSL=false

# ─── OPENAI (optional global fallback) ────────────────────────────────────────
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
AI_RATE_LIMIT_PER_HOUR=20

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://silabuys.uz

# ─── SUPER ADMIN ──────────────────────────────────────────────────────────────
FIRST_SUPERADMIN_EMAIL=admin@silabuys.uz
FIRST_SUPERADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD

# ─── WORKERS ──────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=4
